{
	"ociVersion": "1.2.0",
	"process": {
		"terminal": false,
		"user": {
			"uid": 0,
			"gid": 0
		},
		"args": [
			"/bin/true"
		],
		"env": [
			"PATH=/bin:/usr/bin:/sbin:/usr/sbin"
		],
		"cwd": "/",
		"noNewPrivileges": true
	},
	"root": {
		"path": "__ROOTFS__",
		"readonly": true
	},
	"hooks": {
		"prestart": [
			{
				"path": "/bin/sh",
				"args": [
					"sh",
					"-c",
					"echo 'demo prestart hook: missing required GPU_DEVICE_ID' >&2; echo 'hint: set GPU_DEVICE_ID or fix the CDI/device hook config' >&2; exit 42"
				],
				"env": [
					"CATCHY_DEMO=1"
				],
				"timeout": 5
			}
		]
	},
	"mounts": [
		{
			"destination": "/proc",
			"type": "proc",
			"source": "proc"
		}
	],
	"linux": {
		"namespaces": [
			{
				"type": "pid"
			},
			{
				"type": "ipc"
			},
			{
				"type": "uts"
			},
			{
				"type": "mount"
			},
			{
				"type": "user"
			}
		],
		"uidMappings": [
			{
				"containerID": 0,
				"hostID": "__UID__",
				"size": 1
			}
		],
		"gidMappings": [
			{
				"containerID": 0,
				"hostID": "__GID__",
				"size": 1
			}
		]
	}
}
